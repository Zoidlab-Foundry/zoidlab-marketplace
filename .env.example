# --- ZoidLab Marketplace ---
# Shared ZoidLab SSO secret — MUST match the other *.zoidlab.ai apps to accept
# the shared zb_session cookie. (Backend + frontend both read it.)
BUILDER_SESSION_SECRET=change-me

# Backend
DATA_DIR=./backend/data
PORT=8300
ENABLE_MOCK_SANDBOX=true
# Comma-separated Nyquest user ids (or emails) allowed into /admin/review
MARKETPLACE_ADMINS=

# Frontend
MARKETPLACE_API_URL=http://127.0.0.1:8300
NYQUEST_API=https://api.nyquest.ai
NYQUEST_APP_ORIGIN=https://app.nyquest.ai
SESSION_COOKIE_DOMAIN=.zoidlab.ai
APP_DOMAIN=marketplace.zoidlab.ai

# Local Docker Postgres (the prototype defaults to SQLite; see README)
DATABASE_URL=postgresql://zoidlab:zoidlab@localhost:5432/zoidlab_marketplace
